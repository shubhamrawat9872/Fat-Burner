rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Default-Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Prevent accidental profile deletions

      // Sub-collections under users of interest
      match /dailyLogs/{dateKey} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }

      match /progress/{dateKey} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }
    }
  }
}
